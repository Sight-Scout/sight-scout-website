---
import Layout from '../../layouts/Layout.astro';
import Timeline from '../../components/Timeline.astro';

const items = [
  {
    date: 'March 2024',
    html: '<strong>The spark.</strong> [CONFIRM] Research begins into the gap between how treatable amblyopia is and how inconsistently kids\' vision gets checked.',
  },
  {
    date: 'May 2024',
    html: '<strong>First prototype.</strong> [CONFIRM] A bare-bones acuity activity engine in the browser: visual-angle math, screen calibration, adaptive sizing.',
  },
  {
    date: 'August 2024',
    html: '<strong>Kid-tested design.</strong> [CONFIRM] The engine becomes a scouting game — symbol shapes, missions, rewards for effort.',
  },
  {
    date: 'November 2024',
    html: '<strong>Smarter adaptivity.</strong> [CONFIRM] Adaptive staircase tuned for short attention spans: fewer trials, friendlier pacing.',
  },
  {
    date: 'February 2025',
    html: '<strong>Family feedback round.</strong> [CONFIRM] Informal at-home trials with volunteer families; major usability rework.',
  },
  {
    date: 'June 2025',
    html: '<strong>Privacy, rebuilt.</strong> [CONFIRM] Data architecture redesigned around the FTC\'s amended COPPA rule: minimize, keep local, never sell.',
  },
  {
    date: 'October 2025',
    html: '<strong>Two eyes, two stories.</strong> [CONFIRM] Per-eye protocol refined; the "pirate patch" moment becomes kids\' favorite part.',
  },
  {
    date: 'March 2026',
    html: '<strong>Two years in.</strong> [CONFIRM] Refinement, advisor conversations, and groundwork for launch.',
  },
  {
    date: 'July 2026',
    html: '<strong>This website.</strong> The public face goes live; app release next. [CONFIRM]',
  },
];
---

<Layout
  title="Our Journey"
  description="Sight Scout's timeline, from the first research in March 2024 through the public launch of this website in July 2026 — built slowly, on purpose."
>
  <h1>Building Sight Scout.</h1>
  <p class="mt-4 max-w-prose text-lg text-ink/85">Started March 2024. Built slowly, on purpose.</p>

  <div class="mt-14">
    <Timeline items={items} />
  </div>

  <p class="mt-10 max-w-prose font-display text-lg italic text-ink/80">
    We'd rather ship carefully than quickly — it's kids' vision.
  </p>
</Layout>
