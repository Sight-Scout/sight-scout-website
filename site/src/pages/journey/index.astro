---
import Layout from '../../layouts/Layout.astro';
import Timeline from '../../components/Timeline.astro';

const groups = [
  {
    year: '2024',
    items: [
      {
        date: 'March',
        title: 'Where it started',
        body: 'Started digging into a frustrating gap: amblyopia is common and treatable, but screening between checkups is patchy, so kids slip through. That research folder became a plan.',
      },
      {
        date: 'May',
        title: 'First prototype',
        body: 'A rough acuity activity running in a browser. Visual-angle math, screen calibration, adaptive sizing. Ugly, but the math worked.',
      },
      {
        date: 'August',
        title: 'Making it a game',
        body: 'Symbol shapes, missions, rewards for effort. Testing with actual kids made one thing obvious: if it is not fun, nothing else matters.',
      },
      {
        date: 'November',
        title: 'Smarter adaptivity',
        body: 'Tuned the staircase for short attention spans. Fewer trials, friendlier pacing, same math underneath.',
      },
    ],
  },
  {
    year: '2025',
    items: [
      {
        date: 'February',
        title: 'Family feedback',
        body: 'Volunteer families ran it at home and told us exactly what confused them. A big usability rework followed.',
      },
      {
        date: 'June',
        title: 'Privacy rebuild',
        body: "Redesigned the data architecture around the FTC's amended COPPA rule. Collect less, keep it on the device, never sell.",
      },
      {
        date: 'October',
        title: 'Two eyes, two stories',
        body: 'Refined the per-eye protocol. The pirate patch turned out to be the part kids ask to do again.',
      },
    ],
  },
  {
    year: '2026',
    items: [
      {
        date: 'March',
        title: 'Two years in',
        body: 'Refinement, testing, and groundwork for launch.',
      },
      {
        date: 'July',
        title: 'This website',
        body: 'The public face goes live.',
      },
      {
        date: 'Next',
        title: 'The app',
        body: 'Final testing now. Leave your email on the home page and you will get one message when it ships.',
        accent: 'coral' as const,
      },
    ],
  },
];
---

<Layout
  title="Our Journey"
  description="Sight Scout's timeline, from the first research in March 2024 to the launch of this website in July 2026. Built slowly, on purpose."
>
  <h1>Building Sight Scout.</h1>
  <p class="mt-4 max-w-prose text-lg text-ink/85">Started March 2024. Built slowly, on purpose.</p>

  <div class="mt-14">
    <Timeline groups={groups} />
  </div>

  <p class="mt-12 max-w-prose font-display text-lg italic text-ink/80">
    We would rather ship carefully than quickly. It's kids' vision.
  </p>
</Layout>
