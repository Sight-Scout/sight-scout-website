---
import Layout from '../../layouts/Layout.astro';
import { CONTACT_EMAIL } from '../../lib/site';
---

<Layout
  title="About the Project"
  description="Why Sight Scout exists: a friendly, honest tool that helps parents stay engaged with their child's vision and leads families toward eye care professionals, never away from them."
>
  <h1>About the project.</h1>

  <section class="mt-10">
    <p class="max-w-prose text-ink/85">[FOUNDER_BIO — 2–4 sentences, first person welcome]</p>
  </section>

  <section class="mt-10">
    <p class="max-w-prose text-lg text-ink/90">
      Sight Scout exists because amblyopia is common, treatable, and easy to miss. We believe
      parents deserve friendly, honest tools that make it easier to stay engaged with their
      child's vision — and that the job of such a tool is to lead families toward eye care
      professionals, never to stand in for them.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-lg">Contact</h2>
    <p class="mt-3">
      <a href={`mailto:${CONTACT_EMAIL}`} class="font-semibold text-teal hover:text-teal-dark">{CONTACT_EMAIL}</a>
    </p>
    <p class="mt-1 text-sm text-ink/60">We read everything.</p>
  </section>

  <!-- [ADVISORS — omit section entirely if empty] -->
</Layout>
