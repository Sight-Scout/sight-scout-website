---
// Decorative illustration for the 404 page: a friendly lost scout.
---

<svg viewBox="0 0 400 320" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="An illustrated scout looking at a map, a little lost">
  <ellipse cx="200" cy="290" rx="150" ry="20" fill="var(--color-sky)" />
  <circle cx="80" cy="70" r="26" fill="var(--color-sun)" opacity="0.5" />
  <circle cx="330" cy="110" r="16" fill="var(--color-coral)" opacity="0.6" />

  <g transform="translate(140,110)">
    <rect x="46" y="40" width="24" height="34" rx="8" fill="var(--color-coral)" />
    <path d="M10 70 C 10 45, 35 32, 55 32 C 75 32, 100 45, 100 70 L100 120 C100 132, 88 140, 55 140 C 22 140, 10 132, 10 120 Z" fill="var(--color-teal)" />
    <circle cx="55" cy="14" r="26" fill="#F4C9A0" />
    <path d="M25 6 C 25 -10, 85 -10, 85 6 C 85 12, 79 14, 55 14 C 31 14, 25 12, 25 6 Z" fill="var(--color-sun)" />
    <!-- confused expression -->
    <circle cx="45" cy="16" r="2.5" fill="var(--color-ink)" />
    <circle cx="65" cy="16" r="2.5" fill="var(--color-ink)" />
    <path d="M46 26 Q55 22 64 26" stroke="var(--color-ink)" stroke-width="2" fill="none" stroke-linecap="round" />
    <!-- map -->
    <g transform="translate(-30,60) rotate(-8)">
      <rect x="0" y="0" width="40" height="30" rx="3" fill="#FBF7F0" stroke="var(--color-line)" stroke-width="2" />
      <path d="M6 10 L18 18 L34 8" stroke="var(--color-coral)" stroke-width="2" fill="none" stroke-linecap="round" stroke-dasharray="2 3" />
      <circle cx="34" cy="8" r="2" fill="var(--color-teal)" />
    </g>
  </g>

  <text x="200" y="60" text-anchor="middle" font-family="Fraunces, serif" font-size="22" fill="var(--color-ink)" opacity="0.35">?</text>
</svg>
