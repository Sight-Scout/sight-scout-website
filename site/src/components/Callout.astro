---
interface Props {
  heading?: string;
}
const { heading } = Astro.props;
---

<div class="callout" role="note">
  <svg
    class="mb-2 h-6 w-6 text-teal"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="9" />
    <path d="M12 8v4l2.5 2.5" transform="rotate(45 12 12)" />
    <path d="M12 2.5v2M12 19.5v2M2.5 12h2M19.5 12h2" />
  </svg>
  {heading && <p class="mb-1 font-display text-lg font-bold">{heading}</p>}
  <div class="callout-body">
    <slot />
  </div>
</div>
