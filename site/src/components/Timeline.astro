---
interface Item {
  date: string;
  title: string;
  summary: string;
  detail: string;
  accent?: 'sun' | 'coral';
}

interface YearGroup {
  year: string;
  items: Item[];
}

interface Props {
  groups: YearGroup[];
}

const { groups } = Astro.props;
---

<div class="flex flex-col gap-14">
  {groups.map((group) => (
    <section>
      <h2 class="font-display text-3xl font-bold text-ink/25">{group.year}</h2>
      <ol class="timeline mt-6">
        {group.items.map((item) => (
          <li class={`timeline-item ${item.accent === 'coral' ? 'timeline-item-coral' : ''}`}>
            <details class="group">
              <summary class="cursor-pointer list-none marker:content-none">
                <p class="mb-1 text-sm font-bold uppercase tracking-wide text-teal-dark">{item.date}</p>
                <span class="flex items-baseline gap-3">
                  <h3 class="inline text-lg group-hover:text-teal">{item.title}</h3>
                  <svg
                    class="h-4 w-4 shrink-0 translate-y-0.5 text-teal transition-transform duration-200 group-open:rotate-45"
                    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"
                  >
                    <path d="M12 5v14M5 12h14" />
                  </svg>
                </span>
                <p class="mt-1 max-w-prose text-ink/85">{item.summary}</p>
              </summary>
              <p class="mt-3 max-w-prose rounded-xl bg-sky px-5 py-4 text-[15px] leading-relaxed text-ink/85">
                {item.detail}
              </p>
            </details>
          </li>
        ))}
      </ol>
    </section>
  ))}
</div>
